# Copy to .env.prod and fill real production secrets. Do NOT commit real secrets.
# Postgres
POSTGRES_DB=oswl
POSTGRES_USER=oswl
POSTGRES_PASSWORD=change_me_strong_password

# Spring datasource (override if using separate DB host)
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/${POSTGRES_DB}
SPRING_DATASOURCE_USERNAME=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD=${POSTGRES_PASSWORD}

# JVM profile
SPRING_PROFILES_ACTIVE=prod

# SMTP (use your production SMTP provider credentials)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=prod-smtp-user
SMTP_PASS=prod-smtp-pass

# Ollama or AI endpoint (if using external AI provider in prod)
# If left empty, application should use configured provider or disable AI features
OLLAMA_URL=
