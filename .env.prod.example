# Copy to .env.prod and fill real production secrets. Do NOT commit real secrets.
# See docs/Production-Deployment-Checklist.md

# Postgres
POSTGRES_DB=oswl
POSTGRES_USER=oswl
POSTGRES_PASSWORD=change_me_strong_password

# OsWL prod datasource (required — no defaults in application-prod.yaml)
DB_URL=jdbc:postgresql://db:5432/${POSTGRES_DB}
DB_USERNAME=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}

# VCS token encryption (required in prod). Generate: openssl rand -base64 32
OSWL_ENCRYPTION_KEY=

# Optional: separate HMAC key for trusted-device cookie (recommended)
# OSWL_TRUSTED_DEVICE_HMAC_KEY=

# JVM profile
SPRING_PROFILES_ACTIVE=prod

# Listen address inside the container (default 127.0.0.1; map host port in compose)
SERVER_ADDRESS=127.0.0.1

# SMTP (use your production SMTP provider credentials)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=prod-smtp-user
SMTP_PASS=prod-smtp-pass

# Ollama or AI endpoint (if using external AI provider in prod)
OLLAMA_URL=
