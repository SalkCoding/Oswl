# Copy this file to .env and fill values. Do NOT commit real secrets.
# Gmail (use an App Password for your Google account)
GMAIL_HOST=smtp.gmail.com
GMAIL_PORT=587
GMAIL_USER=your@gmail.com
GMAIL_PASS=your-app-password

# Spring profile to run (default: local)
SPRING_PROFILES_ACTIVE=local

# Ollama local API URL (host.docker.internal allows containers to reach host)
OLLAMA_URL=http://host.docker.internal:11434

# Local Postgres (for docker-compose). Copy secrets into .env, do NOT commit .env.
POSTGRES_DB=oswl
POSTGRES_USER=oswl
POSTGRES_PASSWORD=change_me_local_password

# Spring datasource (defaults to local Postgres values)
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/${POSTGRES_DB}
SPRING_DATASOURCE_USERNAME=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD=${POSTGRES_PASSWORD}
